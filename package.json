{
  "name": "tt-beamer",
  "version": "1.0.7",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node server.mjs",
    "test": "node --test \"test/**/*.test.mjs\"",
    "test:live": "RUN_LIVE_TESTS=1 node --test test/connection-stability/",
    "test:live:isolated": "for f in test/connection-stability/*.test.mjs; do echo \"--- $f ---\"; RUN_LIVE_TESTS=1 node --test \"$f\" || exit 1; done",
    "test:connection-stability": "RUN_LIVE_TESTS=1 node --test test/connection-stability/",
    "test:phase35": "node --test 'test/phase-35-*.test.mjs'",
    "test:live-e2e": "python -m pytest test/live-e2e/ -v",
    "wave0:env": "bash test/wave0-environment-check.sh",
    "wave0:audio": "node --test test/ssr-audio-capture-smoke.test.mjs"
  },
  "dependencies": {
    "mediasoup": "^3.14.0",
    "mediasoup-client": "^3.20.0",
    "puppeteer": "^23.0.0",
    "puppeteer-stream": "^3.0.22"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
